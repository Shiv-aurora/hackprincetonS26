# Copy to frontend/.env and fill in. Never commit the filled .env.

# GEMINI_API_KEY — optional. Only used when the model selector routes a request
# to `gemini-2` (via @google/genai). Anthropic is the primary model; the backend
# handles those calls, so this key is only needed for the optional Gemini path.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL — base URL for the FastAPI backend. Read at build time via
# `import.meta.env.VITE_API_URL`. Must match BACKEND_PORT from the repo-root
# .env.
VITE_API_URL=http://localhost:8000

# Supabase — user auth and activity history.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
