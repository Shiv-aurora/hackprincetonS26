# Copy to `.env` and fill in. Never commit the filled `.env`.

# OpenAI API key — used by src/ngsp/remote_client.py for the cloud LLM calls.
OPENAI_API_KEY=sk-REPLACE_ME

# Hugging Face access token — required for gated Gemma 4 weights download.
HF_TOKEN=hf_REPLACE_ME

# Optional: override the default OpenAI model.
# OPENAI_MODEL=gpt-4o

# Optional: override the local Gemma 4 checkpoint. Default is the smallest instruct
# variant (E2B) for laptops / Apple Silicon. Larger options include google/gemma-4-E4B-it
# and google/gemma-4-27b-it (the latter requires CUDA + quantization on <48GB VRAM).
# GEMMA_MODEL_ID=google/gemma-4-E2B-it

# Optional: device for local inference (cpu | cuda | mps). Auto-detected if unset.
# NGSP_DEVICE=mps

# Optional: quantization for local Gemma (none | 8bit | 4bit).
# NGSP_QUANTIZATION=none

# --- Product build (wired in Step 2+) ---
# Backend (FastAPI) port. The server binds to 0.0.0.0:$BACKEND_PORT.
BACKEND_PORT=8000
# Frontend (Vite) API base URL. Read at build time via `import.meta.env.VITE_API_URL`.
VITE_API_URL=http://localhost:8000

# Supabase — user auth and activity history persistence.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# External MCP/webhook connector endpoints for export action chips.
# These endpoints should perform the real email send / Google Calendar event creation
# and return JSON containing id, message_id, event_id, or external_id.
MCP_EMAIL_URL=
MCP_EMAIL_TO=medical.monitor@example.com
# MCP_EMAIL_WEBHOOK_SECRET=

MCP_CALENDAR_URL=
MCP_CALENDAR_ID=primary
MCP_CALENDAR_ATTENDEES=medical.monitor@example.com
MCP_CALENDAR_TIMEZONE=America/New_York
# Optional fixed demo slot; omit to use tomorrow at 14:00 UTC.
# MCP_CALENDAR_START=2026-04-20T10:00:00-04:00
# MCP_CALENDAR_END=2026-04-20T10:30:00-04:00
# MCP_CALENDAR_WEBHOOK_SECRET=
