# Copy to `.env` and fill in. Never commit the filled `.env`.

# Anthropic API key — used by src/ngsp/remote_client.py for the cloud LLM calls.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Hugging Face access token — required for gated Gemma 4 weights download.
HF_TOKEN=hf_REPLACE_ME

# Optional: override the default Anthropic model.
# ANTHROPIC_MODEL=claude-opus-4-7

# Optional: override the local Gemma 4 checkpoint. Default is the smallest instruct
# variant (E2B) for laptops / Apple Silicon. Larger options include google/gemma-4-E4B-it
# and google/gemma-4-27b-it (the latter requires CUDA + quantization on <48GB VRAM).
# GEMMA_MODEL_ID=google/gemma-4-E2B-it

# Optional: device for local inference (cpu | cuda | mps). Auto-detected if unset.
# NGSP_DEVICE=mps

# Optional: quantization for local Gemma (none | 8bit | 4bit).
# NGSP_QUANTIZATION=none
